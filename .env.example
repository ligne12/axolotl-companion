# =============================================================================
# Axolotl Companion — environment variables
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
NODE_ENV=development
ENV=development
LOG_LEVEL=info
TZ=Europe/Paris

# -----------------------------------------------------------------------------
# vLLM — any model compatible with vLLM works
# VLLM_MODEL can be:
#   - A HuggingFace repo id (e.g. "Qwen/Qwen3.5-9B" — the architectural
#     baseline this project was developed against)
#   - A local path inside the container (mounted via the `models` volume)
# VLLM_EXTRA_FLAGS lets you pass any additional vllm serve flags such as:
#   --reasoning-parser qwen3
#   --enable-auto-tool-choice
#   --tool-call-parser qwen3_coder    (or qwen3_xml — newer)
#   --enable-prefix-caching
#   --enable-chunked-prefill
#   --language-model-only             (drop to enable vision on VL models)
#   --rope-scaling '{"rope_type":"yarn","factor":3,"original_max_position_embeddings":32768}'
# See docs/models.md for SOTA model picks, parser families, and the
# memory budget primer that ties context window × concurrency × util.
# -----------------------------------------------------------------------------
HF_TOKEN=hf_your_token_here
VLLM_MODEL=Qwen/Qwen3.5-9B
VLLM_SERVED_MODEL_NAME=
VLLM_PORT=8000
VLLM_MAX_MODEL_LEN=8192
VLLM_MAX_NUM_SEQS=2
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_MAX_NUM_BATCHED_TOKENS=4096
VLLM_BLOCK_SIZE=16
VLLM_KV_CACHE_DTYPE=auto
VLLM_QUANTIZATION=
VLLM_EXTRA_FLAGS=

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=axolotl
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=axolotl
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://axolotl:change_me_in_production@postgres:5432/axolotl

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Backend (FastAPI)
# -----------------------------------------------------------------------------
BACKEND_PORT=8001
BACKEND_HOST=0.0.0.0
# Generate: openssl rand -hex 32
JWT_SECRET=change_me_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30
# Generate: openssl rand -base64 32
FERNET_KEY=change_me_openssl_rand_base64_32
CORS_ORIGINS=http://localhost:3000,https://chat.localhost

# Backend → vLLM
VLLM_API_URL=http://vllm:8000/v1

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
# Docker stage for the frontend container:
#   production  — `node server.js` from the standalone build (default).
#   development — `pnpm dev` HMR server. Use `make dev-hmr` instead of
#                 setting this by hand if you also want the bind mounts.
FRONTEND_TARGET=production
# Set to "/api" to route backend calls through whatever origin the browser
# is on (chat.localhost, Tailscale, LAN IP, …) — Caddy strips /api and
# forwards to the FastAPI backend. Keep the absolute fallback for local
# pnpm dev without Caddy.
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_APP_NAME=Axolotl Companion
# Auth.js requires AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=change_me_openssl_rand_base64_32
AUTH_URL=https://chat.localhost
NEXTAUTH_URL=https://chat.localhost
# Required for Auth.js when accessed via a proxy (Caddy in our setup)
AUTH_TRUST_HOST=true

# -----------------------------------------------------------------------------
# Public hostnames (optional) — opt-in HTTPS via Let's Encrypt + DNS-01.
#
# Set APP_HOSTNAMES to a comma-separated list of hostnames you've pointed
# at this host (DNS A records to your LAN IP, "DNS only" / unproxied).
# Caddy obtains a real Let's Encrypt cert via the DNS-01 challenge — works
# behind NAT, no public IP needed. Leave blank to keep the stack
# localhost-only.
#
# CF_API_TOKEN: Cloudflare API token scoped to Zone:DNS:Edit on the zones
# above. Create at https://dash.cloudflare.com/profile/api-tokens (template
# "Edit zone DNS"). NEVER commit the token.
#
# Example:
#   APP_HOSTNAMES=axolotl.example.dev, chat.example.dev
#   CF_API_TOKEN=<your-token>
# -----------------------------------------------------------------------------
APP_HOSTNAMES=
CF_API_TOKEN=

# -----------------------------------------------------------------------------
# Observability (optional, profile: obs)
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
LANGFUSE_PORT=3002

# Langfuse traces (optional). Leave the public/secret keys blank to
# disable tracing entirely — the orchestrator's tracer collapses to a
# no-op, no network calls, no startup cost.
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

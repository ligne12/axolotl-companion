    "/v1/sessions/{session_id}/messages": {
      "get": {
        "description": "Return the messages of a session, with tool results merged in.",
        "operationId": "list_messages_v1_sessions__session_id__messages_get",
        "parameters": [
          {
            "in": "path",
            "name": "session_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "title": "Session Id",
              "type": "string"
            }
          }
        ],
        "responses": {

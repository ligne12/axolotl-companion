# =============================================================================
# Consistent line endings across OSes
# =============================================================================

* text=auto eol=lf

# Explicit text files
*.py          text eol=lf
*.ts          text eol=lf
*.tsx         text eol=lf
*.js          text eol=lf
*.jsx         text eol=lf
*.json        text eol=lf
*.md          text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.toml        text eol=lf
*.sh          text eol=lf
*.css         text eol=lf
*.html        text eol=lf
*.sql         text eol=lf
Dockerfile*   text eol=lf
Makefile      text eol=lf
Caddyfile     text eol=lf

# Windows scripts keep CRLF
*.bat         text eol=crlf
*.ps1         text eol=crlf

# Binary
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.ico         binary
*.svg         binary
*.woff        binary
*.woff2       binary
*.pdf         binary

# Lockfiles — merge with ours strategy to minimise conflicts
pnpm-lock.yaml  merge=ours linguist-generated=true
uv.lock         merge=ours linguist-generated=true

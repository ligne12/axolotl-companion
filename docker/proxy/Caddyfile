# =============================================================================
# Caddy config — Axolotl Companion reverse proxy
# Auto TLS via *.localhost (self-signed) in dev, Let's Encrypt in prod
# =============================================================================

{
	# Global options
	email admin@axolotl.local
	# Uncomment for prod:
	# acme_ca https://acme-v02.api.letsencrypt.org/directory
}

# -----------------------------------------------------------------------------
# chat.localhost — frontend on / and backend on /api/* under one origin, so
# the Next.js bundle can use a relative NEXT_PUBLIC_API_URL (/api) that works
# from every entry point (chat.localhost, Tailscale, LAN IP, …) without the
# cross-origin cookie dance.
# -----------------------------------------------------------------------------
chat.localhost {
	tls internal

	encode gzip zstd

	# CSP and security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}

	# NextAuth owns /api/auth/* on the frontend (CSRF, session, callbacks,
	# providers, error page, …). It happens to share the /api/auth namespace
	# with our FastAPI /auth/* routes but the leaf paths don't collide, so we
	# can split by matching NextAuth's exact endpoints.
	@nextauth path /api/auth/signin /api/auth/signin/* /api/auth/signout /api/auth/signout/* /api/auth/callback /api/auth/callback/* /api/auth/session /api/auth/csrf /api/auth/providers /api/auth/error /api/auth/verify-request /api/auth/_log
	handle @nextauth {
		reverse_proxy frontend:3000 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	handle_path /api/* {
		reverse_proxy backend:8001 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}

			# SSE support: disable buffering
			flush_interval -1
		}
	}

	handle {
		reverse_proxy frontend:3000 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
}

# -----------------------------------------------------------------------------
# Public hostnames — opt-in HTTPS via Let's Encrypt + DNS-01 challenge.
# Activated by setting APP_HOSTNAMES + CF_API_TOKEN in .env. Defaults to a
# bogus TLD so the block is dormant when unset (other sites keep working).
# Same routing shape as chat.localhost (NextAuth split, /api/* to backend).
# -----------------------------------------------------------------------------
{$APP_HOSTNAMES:lan-disabled.invalid} {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
	}

	encode gzip zstd

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}

	@nextauth path /api/auth/signin /api/auth/signin/* /api/auth/signout /api/auth/signout/* /api/auth/callback /api/auth/callback/* /api/auth/session /api/auth/csrf /api/auth/providers /api/auth/error /api/auth/verify-request /api/auth/_log
	handle @nextauth {
		reverse_proxy frontend:3000
	}

	handle_path /api/* {
		reverse_proxy backend:8001 {
			flush_interval -1
		}
	}

	handle {
		reverse_proxy frontend:3000
	}
}

# -----------------------------------------------------------------------------
# api.localhost — legacy direct-to-backend origin, kept around for
# server-to-server scripts. New code should use chat.localhost/api/… instead.
# -----------------------------------------------------------------------------
api.localhost {
	tls internal

	encode gzip zstd

	# CORS handled by FastAPI
	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
	}

	reverse_proxy backend:8001 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}

		# SSE support: disable buffering
		flush_interval -1
	}
}
